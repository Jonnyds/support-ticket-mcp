# Only needed for the search_tickets tool (semantic search).
# The SQL tools work without it.
OPENAI_API_KEY=sk-your-key-here

# Optional overrides (defaults shown):
# OPENAI_EMBED_MODEL=text-embedding-3-small
# SEARCH_MIN_SIMILARITY=0.30          # relevance floor for search (0-1)
# TICKETS_CSV=/absolute/path/to/your/tickets.csv
# DATASET_URL=https://huggingface.co/...   # used by download_data.py
